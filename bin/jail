#!/bin/bash

args=(
  --new-session
  --die-with-parent

  --unshare-all
  # --share-net
  --hostname localhost

  --clearenv
  --setenv PATH "/usr/sbin:/usr/bin"

  --ro-bind /usr /usr
  --symlink /usr/lib64 /lib64

  --ro-bind /etc/localtime /etc/localtime

  # --proc /proc
  # --dev /dev
  # --tmpfs /run
  # --tmpfs /tmp
)

exec bwrap "${args[@]}" "$@"
