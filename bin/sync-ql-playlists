#!/bin/bash

. "$( dirname "$0" )/lib.sh"
set-icon "󰎆"

MUSIC="/slack/music"
QUERIES=~/.config/quodlibet/lists/queries.saved

ql running >/dev/null || ql start-hidden "$@"
while ! ql running >/dev/null; do
  sleep 1
done

status "Exporting playlists..."

while read -r query; do
  read -r title
  [[ "$title" =~ ^(Default|Added|Rated) ]] || continue

  playlist="$MUSIC/$title.m3u"
  files=$( quodlibet --print-query="$query" | sed -r "s,^(/mnt)?$MUSIC/,," | sort )

  if [ -f "$playlist" ]; then
    previous=$( wc -l < "$playlist" )
  else
    previous=0
  fi

  if [ -n "$files" ]; then
    count=$( echo "$files" | wc -l )
    diff=$(( count - previous ))
    indent 2
    info "{{$title}}: $count songs $( [ $diff -ne 0 ] && printf '\e[1;32m(%+d)' "$diff" )"
    echo "$files" > "$playlist"
  else
    indent 2
    warning "{{$title}: No songs, deleting... {{(-$previous)}}"
    rm -f "$playlist"
  fi
done < "$QUERIES"

# TODO: Create links for phone syncing

