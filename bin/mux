#!/bin/bash

PROJECT=$( basename "$PWD" )

function usage {
  echo "Usage: mux [OPTIONS] [--] [COMMAND...]"
  echo
  echo "Commands:"
  echo "  mux                   Create a new window"
  echo "  mux COMMAND...        Run a command in a new window"
  echo "  mux @PROCESS          Run a process from a Procfile in a new window"
  echo
  echo "  mux loop COMMAND..    Run a command in a loop"
  echo "  mux title TITLE       Set the current tmux window title"
  echo
  echo "Options:"
  echo "  -t TITLE    Specify title for new window"
  echo "  -s          Split window horizontally"
  echo "  -b          Split small window horizontally"
  echo "  -v          Split window vertically"
  echo "  -d          Detach new window"
  echo "  -l          Loop command in window"
  echo "  -w          Wait after command exits"
  echo
  exit 255
}

function is-elixir  { [ -f mix.exs ]; }
function is-phoenix { is-elixir && grep -Fq :phoenix mix.exs; }
function is-ruby    { [ -f Gemfile ]; }
function is-rails   { is-ruby && [ -x bin/rails ]; }
function is-godot   { [ -f project.godot ]; }

function run {
  action="new-window"
  args=()
  unset title loop wait

  while [ "${1:0:1}" = "-" ]; do
    case "$1" in
      --)
        shift
        break
        ;;
      -t)
        title="$2"
        shift
        ;;
      -s)
        action="split-window"
        args+=( -v )
        ;;
      -b)
        action="split-window"
        args+=( -vfl 25% )
        ;;
      -v)
        action="split-window"
        args+=( -h )
        ;;
      -d)
        args+=( -d )
        ;;
      -l)
        loop=1
        ;;
      -w)
        wait=1
        ;;
      *)
        usage
        ;;
    esac

    shift
  done

  command=( "$@" )

  if [ $# -eq 0 ]; then
    command=( bash --login )
  elif [ -z "$title" ]; then
    title="$* [$PROJECT]"
  fi

  if [ "$loop" ]; then
    command=( "$0" loop "${command[@]}" )
  fi

  if [ "$wait" ]; then
    wait="echo -ne '\n\e[1;32m ● \e[22mDone: [ \e[1m$*\e[22m ]\e[0m '; read -n 1"
  fi

  tmux $action "${args[@]}" -- "
    $0 title '$title';
    ${command[*]};
    $wait
  " || tmux display "Pane too small"
}

case "$1" in
  help)
    usage
    ;;
  @*)
    proc="${1:1}"
    shift

    # Run a process from a Procfile
    if [ -f Procfile ]; then
      commands=$( grep -Eo "^$proc.*:.+" Procfile )
      count=$( echo "$commands" | grep -c . )

      if [ "$count" -gt 0 ]; then
        echo "$commands" | while read -r command; do
          localproc=$( echo "$command" | cut -d: -f1 )
          command=$( echo "$command" | cut -d: -f2- )
          title=${localproc:${#proc}+1}
          title=${title:-$localproc}

          run -d -l -t "@$title [$PROJECT]" -d "$@" "$command"
        done

        exit
      fi
    fi

    command="$proc $*"
    args=( -b )

    # Or run a default process
    case "$proc" in
      bundle)
        function run-bundle {
          run -b -d -w -t "@bundle: $* [$PROJECT]" -- "$@"
        }

        if [ -f mise.toml ]; then
          run-bundle mise install
        fi

        if is-phoenix; then
          run-bundle mix setup
        elif is-elixir; then
          run-bundle mix deps.get
        elif is-ruby; then
          run-bundle bundle
        fi

        if [ -f bun.lock ]; then
          run-bundle bun install
        elif [ -f yarn.lock ]; then
          run-bundle yarn install
        elif [ -f package.json ]; then
          run-bundle npm install
        fi

        exit 0
        ;;
      console)
        if is-elixir; then
          command="iex -S mix"
        elif is-rails; then
          command="rails console"
        else
          echo "Can't find console for project."
          exit 1
        fi
        ;;
      dev)
        args=( -d -l )

        if [ -x bin/dev ]; then
          command="bin/dev"
        else
          exec $0 @server
        fi
        ;;
      edit)
        if is-godot; then
          exec start godot project.godot "$@"
        else
          exec sensible-vim "$@"
        fi
        ;;
      log)
        if [ -f "log/development.log" ]; then
          command="tail -n 0 -f log/development.log"
        else
          echo "Can't find log for project."
          exit 1
        fi
        ;;
      migrate)
        args=( -b -d -w )

        if is-phoenix; then
          command="mix ecto.migrate"
        elif is-rails; then
          command="bundle exec rake db:migrate; [ -f db/schema.rb ] && git checkout db/schema.rb; [ -f db/structure.sql ] && git checkout db/structure.sql"
        else
          echo "Can't find migrations for project."
          exit 1
        fi
        ;;
      run)
        if is-godot; then
          exec godot "$@"
        else
          exec $0 @server
        fi
        ;;
      server)
        args=( -d -l )

        if is-phoenix; then
          command="mix phx.server"
        elif is-rails; then
          command="rails server"
        else
          echo "Can't find server for project."
          exit 1
        fi
        ;;
      *)
        echo "Can't find process '@$proc'"
        exit 1
        ;;
    esac

    run -t "@$proc [$PROJECT]" "${args[@]}" "$@" -- "$command"
    ;;

  loop)
    shift
    command=( "$@" )

    while true; do
      clear
      trap 'kill -9 %1' INT
      "${command[@]}"
      wait
      trap - INT

      >&2 echo -ne "
 \\e[0;34m[ \\e[1m${command[*]}\\e[22m ]•••
   \\e[0;36m● \\e[1mR\\e[22mestart command
   \\e[0;36m● \\e[1mE\\e[22mxecute another command
   \\e[0;33m● \\e[1mQ\\e[22muit
 \\e[0;32m•••\\e[0m "

      read -rn 1 2>/dev/null || exit
      echo

      case "$REPLY" in
        [rR]*|"")
          continue
          ;;
        [eE]*)
          echo -ne "  \\e[0;34m•• \\e[1;34mcommand:\\e[0m "
          read -r
          command=( "$REPLY" )
          ;;
        *)
          echo
          exit
          ;;
      esac
    done
    ;;

  title)
    [ $# -eq 2 ] || usage
    [ "$NVIM" ] && exit

    title="$2"
    echo -ne "\e]2;$title\007" >&2
    ;;

  *)
    run "$@"
    ;;
esac
