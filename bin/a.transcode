#!/bin/bash

if [ -z "$1" ]; then
  echo "Usage: $0 [-f FORMAT] FILES"
  exit
fi

if [ $# -eq 1 ] && [ "$( basename "$1" )" = "converted" ]; then
  mv -vi "$1"/* . && rmdir -v "$1"
  exit
fi

format=flac

while [ $# -gt 0 ]; do
  case "$1" in
    -f ) format="$2"; shift 2;;
    *  ) break;;
  esac
done

readarray -d '' files < <( find "$@" -type f ! -path '*/converted/*' -print0 | sort -z )

for file in "${files[@]}"; do
  ext=${file##*.}
  dirname=$( dirname "$file" )
  basename=$( basename "$file" ".$ext" )
  options=()

  mime=$( file -b --mime-type "$file" )
  if [ "${mime:0:6}" != "audio/" ]; then
    echo " [1;33mā—¸[22m Skipping: [1m$file[0m"
    continue
  fi

  case "$format" in
    wav)
      options+=( -sample_fmt s16 )
      ;;
    flac)
      if file "$file" | grep -Eq '24 bit.* (96|192) kHz'; then
        options+=( -sample_fmt s16 -ar 48000 )
      else
        options+=( -sample_fmt s16 )
      fi
      ;;
    mp3)
      options+=( -q:a 0 ) # best VBR
      ;;
    ogg)
      options+=( -q:a 6 ) # ~192kbps VBR
      ;;
  esac

  target="$dirname/converted/$basename.$format"
  mkdir -p "$( dirname "$target" )"

  echo " [1;32mā—¸[22m Converting: [1m$basename [1;33m{[1m.$ext[22m => [1m.$format[22m}[0m "
  ffmpeg -loglevel warning -i "$file" "${options[@]}" "$target"
done
