#!/bin/bash

trap 'exit 1' INT

if [ "$HOSTNAME" = "ocelot" ]; then
  target="schtube"
else
  target="ocelot"
fi

if [ $# -eq 0 ]; then
  set -- music sound photos games
fi

for path in "$@"; do
  echo
  echo -e " \e[1;32m●\e[22m \e[22mSyncing \e[1m$path\e[22m with \e[1;33m$target\e[0m"

  args=()
  case "$path" in
    games)
      args+=(
        -ignore 'Path steam'
        -ignore 'Path retrodeck'
      )

      [ "$HOSTNAME" = "meerkat" ] && args+=(
        -ignore 'Path roms'
      )
      ;;
  esac

  unison \
    -log=false \
    -fastcheck=true \
    -links=true \
    -times \
    -sortnewfirst \
    -ignoreinodenumbers \
    "${args[@]}" \
    "/slack/$path/" \
    "ssh://$target//slack/$path/"
done

echo
