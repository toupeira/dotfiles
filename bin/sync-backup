#!/bin/bash

. "$( dirname "$0" )/lib.sh"

case "$HOSTNAME" in
  ocelot)
    BACKUP="/mnt/slack"
    DIRS=( backups books documents images music photos scrapbook sound )
    ;;
  *)
    echo "Unsupported host $HOSTNAME"
    exit 1
    ;;
esac

if ! mountpoint -q "$BACKUP"; then
  echo "$BACKUP is not mounted."
  exit 1
fi

cd /slack || exit 1

echo
msg "Syncing backups to {{$BACKUP}}..."

rsync -av --update --delete \
  "${DIRS[@]}" "$BACKUP" "$@"

echo
