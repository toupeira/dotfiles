#!/bin/bash

. "$( dirname "$0" )/lib.sh"

merged_branches=$(
  git branch --format '%(refname:short)' --merged \
    | grep -v ' detached ' \
    | grep -Evx "$( git default-branch )|$( git rev-parse --abbrev-ref HEAD )|develop|development"
)

for branch in $merged_branches; do
  if ask-yes "Remove branch \e[1;33m$branch\e[1;37m?"; then
    git branch -d "$branch"
  fi
done
