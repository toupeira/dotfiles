#!/bin/bash

QL=~/.config/quodlibet
CONTROL=$QL/control
CONFIG=$QL/config

command="$1"
argument="$2"

case "$command" in
  start-hidden)
    shift

    if [ -f "$CONFIG" ] && grep -q "^query_text = *$" "$CONFIG"; then
      default_query=$( head -1 "$QL/lists/queries.saved" | sed -r 's/&/\\&/' )
      sed -ri "s/^(query_text =).*/\1 $default_query/" "$CONFIG"
    fi

    quodlibet --run --start-hidden "$@" &>/dev/null &
    exit
    ;;
  start-playing)
    exec $0 start-hidden --play
    ;;
  rating)
    icon="quodlibet"
    stars="Rating set to "

    for _ in $( seq 0.2 0.2 "$argument" ); do
      stars="$stars⭐"
    done

    filename=$( awk -F= '/^~filename=/ { print $2 }' $QL/current 2>/dev/null )
    if [ -f "$filename" ]; then
      cover=$( find "$( dirname "$filename" )"/cover.* 2>/dev/null | head -1 )
      [ -f "$cover" ] && icon="$cover"
    fi

    title=$( awk -F= '/^title=/ { print $2 }' $QL/current 2>/dev/null )
    album=$( awk -F= '/^album=/ { print $2 }' $QL/current 2>/dev/null )
    artist=$( awk -F= '/^artist=/ { print $2 }' $QL/current 2>/dev/null | sed -rz  's/\n(.)/, \1/g' )

    text="$title"
    [ "$album" ] && text="$text • $album"
    text="$text • $artist"

    notify -a "Quod Libet" -i "$icon" "$text" "$stars"
    ;;
esac

if [ ! -p "$CONTROL" ] || ! pgrep -x quodlibet &>/dev/null; then
  echo "Quod Libet is not running."
  exit 1
elif [ "$command" = "running" ]; then
  exit 0
fi

if [ -n "$argument" ]; then
  echo "$command $argument" > "$CONTROL"
else
  echo "$command" > "$CONTROL"
fi
